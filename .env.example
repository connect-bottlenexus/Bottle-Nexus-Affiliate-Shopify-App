SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=read_products,write_products,read_publications,write_publications,read_content,write_content,read_online_store_pages,write_online_store_pages,read_themes,write_themes,read_inventory,write_inventory,read_locations,read_legal_policies,write_legal_policies
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Source marketplace Admin API credentials.
# Use an Admin API access token for captaincaskwell.myshopify.com.
# The Shopify client secret is not an Admin API token and should not be used here.
CAPTAIN_CASKWELL_SHOP_DOMAIN=captaincaskwell.myshopify.com
CAPTAIN_CASKWELL_ADMIN_ACCESS_TOKEN=
CAPTAIN_CASKWELL_API_VERSION=2026-01
